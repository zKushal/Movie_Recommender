    "def recommend(title, n=10, min_rating=5.0, min_votes=100):\n",
    "    \"\"\"\n",
    "    Content-based movie recommender using TF-IDF + Cosine Similarity\n",
    "    \n",
    "    Parameters:\n",
    "    -----------\n",
    "    title      : str   → movie title (lowercase)\n",
    "    n          : int   → number of recommendations (default 10)\n",
    "    min_rating : float → minimum vote average filter (default 5.0)\n",
    "    min_votes  : int   → minimum vote count filter  (default 100)\n",
    "    \n",
    "    Returns:\n",
    "    --------\n",
    "    DataFrame with top N recommended movies\n",
    "    \"\"\"\n",
    "    if title not in indices:\n",
    "        print(f\"❌ '{title}' not found!\")\n",
    "        print(f\"\\nDid you mean:\")\n",
    "        matches = [t for t in movies['title'] if title.split()[0] in t]\n",
    "        for m in matches[:5]: print(f\"   → {m}\")\n",
    "        return None\n",
    "\n",
    "    idx         = indices[title]\n",
    "    sim_scores  = sorted(list(enumerate(cosine_sim[idx])),\n",
    "                         key=lambda x: x[1], reverse=True)[1:]\n",
    "    top_50_idx  = [i[0] for i in sim_scores[:50]]\n",
    "    top_50_sim  = [i[1] for i in sim_scores[:50]]\n",
    "\n",
    "    results = movies[['title', 'genres', 'vote_average', 'vote_count',\n",
    "                       'release_year', 'director', \n",
    "                       'popularity']].iloc[top_50_idx].copy()\n",
    "    results['similarity']    = top_50_sim\n",
    "    results['norm_rating']   = results['vote_average'] / 10.0\n",
    "    results['weighted_score'] = (0.60 * results['similarity'] +\n",
    "                                  0.40 * results['norm_rating'])\n",
    "\n",
    "    results = results[\n",
    "        (results['vote_average'] >= min_rating) &\n",
    "        (results['vote_count']   >= min_votes)\n",
    "    ].sort_values('weighted_score', ascending=False).head(n)\n",
    "\n",
    "    results = results.reset_index(drop=True)\n",
    "    results.index += 1\n",
    "\n",
    "    print(f\"\\n🎬 Because you watched: '{title}'\")\n",
    "    print(f\"{'='*70}\")\n",
    "    print(f\"{'#':<4} {'Title':<32} {'Sim':>6} {'Rating':>7}\"\n",
    "          f\" {'Score':>7} {'Year':>6}\")\n",
    "    print(f\"{'-'*70}\")\n",
    "    for i, row in results.iterrows():\n",
    "        print(f\"{i:<4} {row['title'][:31]:<32} \"\n",
    "              f\"{row['similarity']:>6.4f} \"\n",
    "              f\"{row['vote_average']:>7.1f} \"\n",
    "              f\"{row['weighted_score']:>7.4f} \"\n",
    "              f\"{int(row['release_year']):>6}\")\n",
    "    return results\n",
    "\n",
    "print(\"✅ Recommend function ready!\")\n",
    "print(\"\\n── Quick test ──\")\n",
    "recommend('inception')"
   ]
